{
  "mcpServers": {
    "replicate-image": {
      "command": "/Users/mk/Development/claude-code-20260521/_mcp/replicate_image/.venv/bin/python",
      "args": [
        "/Users/mk/Development/claude-code-20260521/_mcp/replicate_image/server.py"
      ],
      "env": {
        "REPLICATE_API_TOKEN": "r8_REPLACE_WITH_YOUR_TOKEN"
      }
    },
    "Canvas": {
      "type": "http",
      "url": "https://canvas-mcp.ai.huit.harvard.edu/mcp",
      "headers": {
        "X-Canvas-API-Token": "YOUR_CANVAS_API_TOKEN",
        "X-Canvas-API-URL": "https://harvard.beta.instructure.com"
      }
    }
  }
}
